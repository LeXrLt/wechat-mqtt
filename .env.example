# 日志级别 DEBUG/INFO/WARNING/ERROR
LOG_LEVEL=DEBUG

# MQTT 连接配置（需与 wechat-listener 的 mqtt 配置一致）
MQTT_HOST=127.0.0.1
MQTT_PORT=1883
MQTT_USERNAME=weixin
MQTT_PASSWORD=YOUR_MQTT_PASSWORD
MQTT_CLIENT_ID=wechat-mqtt
MQTT_TOPIC=wechat/messages

# 启用的处理器（逗号分隔），为空则启用全部。例如：debug,persist
ENABLED_HANDLERS=

# PostgreSQL 数据库配置
POSTGRES_USER=wechat
POSTGRES_PASSWORD=wechat
POSTGRES_DB=wechat

# 语义向量维度（需与生成 embedding 的模型一致，如 OpenAI text-embedding-3-small 为 1536）
EMBEDDING_DIM=1536

# 启动时是否自动执行数据库迁移
RUN_MIGRATIONS=true

# Adminer Web 管理界面映射端口
ADMINER_PORT=8080
